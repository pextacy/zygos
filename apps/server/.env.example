# Server-only environment (CLAUDE.md §9). Copy to .env — never commit .env.
PORT=8080
TXLINE_ORIGIN=https://txline-dev.txodds.com   # or https://txline.txodds.com for mainnet
TXLINE_API_TOKEN=      # from `pnpm -F server txline:activate` (on-chain free-tier subscription)
JUPITER_API_KEY=       # Jupiter Predict API key (candidate venue — see docs/venue-selection.md)
RPC_URL=               # Helius/Triton mainnet or devnet endpoint (defaults per CLUSTER for the activation script)
CLUSTER=devnet         # 'mainnet-beta' | 'devnet' — must match venue adapter deployment
DATABASE_URL=            # Neon: postgres://USER:PASSWORD@ep-xxx.REGION.aws.neon.tech/neondb?sslmode=require
                         # unset/local path -> embedded PGlite dir (zero-setup dev); memory:// -> in-memory (tests)
DELEGATION_ENC_KEY=      # at-rest AES key for stored pre-signed delegation txs (64-hex or passphrase). Set before production.
COMMITMENT_MEMO=true
WEB_ORIGIN=            # comma-separated browser origins for CORS (e.g. https://zygos.vercel.app); unset = allow all
ADMIN_WALLETS=         # comma-separated wallets allowed to edit /bindings; unset = any signature-verified wallet (dev only)
