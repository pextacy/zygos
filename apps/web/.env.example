# Web environment (CLAUDE.md §9): ONLY these two NEXT_PUBLIC_ vars may reach
# the browser — TxLINE/venue credentials never do. Copy to .env.local.
NEXT_PUBLIC_SERVER_WS_URL=ws://localhost:8080/ws   # wss://<your-fly-app>.fly.dev/ws in production
NEXT_PUBLIC_CLUSTER=devnet                         # 'mainnet-beta' | 'devnet' — must match the server
